            {"UserName": "alice", "MFAEnabled": true},
            {"UserName": "charlie", "MFAEnabled": true},
            {"UserName": "bob", "MFAEnabled": false}
        ]
    },
    "roles": [
        {"RoleName": "Admin", "AssumeRolePolicyDocument": {}}
    ]
}
